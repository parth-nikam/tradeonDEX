generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ModelConfig {
  id           Int               @id @default(autoincrement())
  name         String
  apiModelName String
  accountIndex Int               @default(0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  invocations  ModelInvocation[]
}

model ModelInvocation {
  id          Int         @id @default(autoincrement())
  modelId     Int
  model       ModelConfig @relation(fields: [modelId], references: [id])
  prompt      String      @db.Text
  response    String      @db.Text
  totalCost   Float       @default(0)
  timestamp   DateTime    @default(now())
  toolCalls   ToolCall[]
}

model ToolCall {
  id            Int             @id @default(autoincrement())
  invocationId  Int
  invocation    ModelInvocation @relation(fields: [invocationId], references: [id])
  toolName      String
  parameters    Json
  result        Json
  timestamp     DateTime        @default(now())
}

model PortfolioSnapshot {
  id             Int      @id @default(autoincrement())
  totalValue     Float
  availableCash  Float
  positions      Json
  timestamp      DateTime @default(now())
}

model TradeRecord {
  id           Int      @id @default(autoincrement())
  modelId      Int
  symbol       String
  side         String   // "long" | "short"
  quantity     Float
  leverage     Int
  entryPrice   Float
  exitPrice    Float?
  pnl          Float?
  status       String   @default("open") // "open" | "closed" | "failed"
  openedAt     DateTime @default(now())
  closedAt     DateTime?
  reasoning    String?  @db.Text
}
