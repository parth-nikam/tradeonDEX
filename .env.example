# ── Database ──────────────────────────────────────────────────────────────────
# NeonDB (recommended): https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── LLM ───────────────────────────────────────────────────────────────────────
# OpenRouter API key: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-..."

# ── Lighter DEX ───────────────────────────────────────────────────────────────
# Your Ethereum wallet address (for reading account/positions)
LIGHTER_WALLET_ADDRESS="0x..."
# Private key for signing orders (keep secret!)
LIGHTER_PRIVATE_KEY="0x..."
# API base URL (default: mainnet)
LIGHTER_API_URL="https://mainnet.zklighter.elliot.ai"

# ── Trading Parameters ────────────────────────────────────────────────────────
TRADING_BUDGET_USD=50
MAX_LEVERAGE=5
CANDLE_RESOLUTION=5m
CANDLE_COUNT=50

# ── Server ────────────────────────────────────────────────────────────────────
API_PORT=3001
# 0 = use PM2 cron (5 min). Set to 60000 for 1-min high-frequency mode.
LOOP_INTERVAL_MS=0

# ── High-Frequency Mode (AWS c5.large recommended) ────────────────────────────
# Switch to 1m candles + 1-min loop for faster signal detection
# CANDLE_RESOLUTION=1m
# CANDLE_COUNT=100
# LOOP_INTERVAL_MS=60000

NODE_ENV=development
