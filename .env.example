# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
# Auto-generated by CloudFormation — see DatabaseURL output
DATABASE_URL="postgresql://trader:TraderPass2024!@<rds-endpoint>:5432/traderdb"

# ── LLM (AWS Bedrock — no API key needed, uses EC2 IAM role) ─────────────────
AWS_REGION="ap-south-1"
# Model is configured in DB via seed.ts — default: claude-3-5-sonnet-20241022-v2:0

# ── Paper Trading (Stage 1 — real prices, simulated execution) ────────────────
# Real market data from Binance public API (no auth needed)
# Set PAPER_TRADING=false in Stage 2 to enable real Lighter DEX execution
PAPER_TRADING=true
TRADING_BUDGET_USD=10000
MAX_LEVERAGE=5
CANDLE_RESOLUTION=5m
CANDLE_COUNT=50

# ── Lighter DEX (Stage 2 — leave blank for paper trading) ────────────────────
LIGHTER_WALLET_ADDRESS=
LIGHTER_PRIVATE_KEY=
LIGHTER_API_URL=https://mainnet.zklighter.elliot.ai

# ── Server ────────────────────────────────────────────────────────────────────
API_PORT=3001
# 0 = PM2 cron (5 min). 60000 = 1-min high-frequency mode.
LOOP_INTERVAL_MS=0

NODE_ENV=production
